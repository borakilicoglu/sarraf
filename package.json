{
  "name": "sarraf",
  "version": "1.0.0",
  "description": "Dependency analysis CLI for JavaScript and TypeScript projects with optional AI-powered insights.",
  "main": "dist/index.js",
  "bin": {
    "sarraf": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts .",
    "scan": "tsx src/index.ts .",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "test": "npm run build && node --test test/**/*.test.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "dependency-analysis",
    "dependency-hygiene",
    "javascript",
    "typescript",
    "cli",
    "ai"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
